{
  "id": "flatpak-manager",
  "name": "Flatpak Manager",
  "version": "1.0.6",
  "minNoctaliaVersion": "4.4.1",
  "author": "Noctalia",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Full Flatpak management: search, install, uninstall, update, run, kill flatpaks with multiple remotes support",
  "tags": [
    "Launcher",
    "Panel"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "launcherProvider": "LauncherProvider.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "defaultScope": "user",
      "enabledRemotes": [
        "flathub",
        "flathub-beta"
      ],
      "appstreamUpdated": false
    }
  }
}
